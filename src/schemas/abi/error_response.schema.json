{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fits.local/schemas/abi/error_response.schema.json",
  "title": "libfits error response",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok", "error"],
  "properties": {
    "ok": { "const": false },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    }
  }
}
