{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fits.local/schemas/hooks_response.schema.json",
  "title": "fits hook response (stdout JSON)",
  "description": "Hook stdout JSON for protocol version 2. Each array reports validation for graph objects of that kind (**nodes** or **links**).",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol_version"],
  "properties": {
    "protocol_version": { "type": "integer", "const": 2 },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/itemResult" }
    },
    "links": {
      "type": "array",
      "items": { "$ref": "#/$defs/itemResult" }
    }
  },
  "$defs": {
    "hookError": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "pointer": { "type": "string" }
      }
    },
    "itemResult": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "status"],
      "properties": {
        "id": { "type": "string" },
        "status": { "type": "string", "enum": ["ok", "invalid"] },
        "parsed": {},
        "errors": {
          "type": "array",
          "items": { "$ref": "#/$defs/hookError" }
        }
      }
    }
  }
}
