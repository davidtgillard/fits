{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fits.local/schemas/registry.schema.json",
  "title": "fits registry",
  "description": "Machine-owned allocation state at .fits/registry.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["description", "version", "kind", "node_types"],
  "properties": {
    "description": {
      "type": "string",
      "const": "Tracks registered node types (abstract and concrete), link types, numeric id counters, and tombstones. Do not edit by hand; use the fits CLI."
    },
    "version": { "const": 1 },
    "kind": { "const": "fits-registry" },
    "node_types": {
      "type": "array",
      "items": { "$ref": "#/$defs/nodeType" }
    },
    "link_types": {
      "type": "array",
      "items": { "$ref": "#/$defs/linkType" },
      "default": []
    }
  },
  "$defs": {
    "typeName": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
    },
    "nextCounter": {
      "type": "integer",
      "minimum": 1
    },
    "gitCommit": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{40}$"
    },
    "tombstone": {
      "type": "object",
      "additionalProperties": false,
      "required": ["n"],
      "properties": {
        "n": {
          "type": "integer",
          "minimum": 1
        },
        "git_commit": {
          "$ref": "#/$defs/gitCommit"
        }
      }
    },
    "nodeTypeAbstract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "abstract"],
      "properties": {
        "type": { "$ref": "#/$defs/typeName" },
        "abstract": { "const": true }
      }
    },
    "nodeTypeConcrete": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "extends", "next"],
      "properties": {
        "type": { "$ref": "#/$defs/typeName" },
        "abstract": { "const": false },
        "id_prefix": { "$ref": "#/$defs/typeName" },
        "extends": { "$ref": "#/$defs/typeName" },
        "next": { "$ref": "#/$defs/nextCounter" },
        "tombstones": {
          "type": "array",
          "items": { "$ref": "#/$defs/tombstone" },
          "default": []
        }
      }
    },
    "nodeTypeConcreteStandalone": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "next"],
      "properties": {
        "type": { "$ref": "#/$defs/typeName" },
        "abstract": { "const": false },
        "id_prefix": { "$ref": "#/$defs/typeName" },
        "next": { "$ref": "#/$defs/nextCounter" },
        "tombstones": {
          "type": "array",
          "items": { "$ref": "#/$defs/tombstone" },
          "default": []
        }
      }
    },
    "nodeType": {
      "oneOf": [
        { "$ref": "#/$defs/nodeTypeAbstract" },
        { "$ref": "#/$defs/nodeTypeConcrete" },
        { "$ref": "#/$defs/nodeTypeConcreteStandalone" }
      ]
    },
    "linkType": {
      "type": "object",
      "additionalProperties": false,
      "required": ["link_type", "in_type", "out_type", "next"],
      "properties": {
        "link_type": { "$ref": "#/$defs/typeName" },
        "in_type": { "$ref": "#/$defs/typeName" },
        "out_type": { "$ref": "#/$defs/typeName" },
        "next": { "$ref": "#/$defs/nextCounter" },
        "tombstones": {
          "type": "array",
          "items": { "$ref": "#/$defs/tombstone" },
          "default": []
        }
      }
    }
  }
}
